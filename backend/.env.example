# ============================================
# MULTI-PROVIDER AI CONFIGURATION
# Optimized for cost/performance/quality
# ============================================

# 1. Draft & Brainstorm (Wiro - Google Gemini Flash)
GEMINI_API_KEY=your_wiro_api_key_here
GEMINI_MODEL=google/gemini-3-flash

# Final Story (Wiro Run API). Requires WIRO_API_KEY.
# GPT_MODEL: openai/gpt-oss-20b | openai/gpt-5-nano
GPT_API_KEY=your_wiro_api_key_here
GPT_BASE_URL=https://api.wiro.ai/v1
GPT_MODEL=openai/gpt-oss-20b

# Embeddings (Gemini)
EMBEDDING_API_KEY=your_gemini_api_key_here
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDING_MODEL=models/gemini-embedding-001

# 4. STT (Speech to Text) - Whisper Turkish
STT_API_KEY=your_wiro_api_key_here
STT_BASE_URL=https://api.wiro.ai/v1
STT_MODEL=openai/whisper-large-v3-turbo-turkish

# 6. Video (Wiro - Google Veo3)
VIDEO_MODEL=google/veo3-fast
VIDEO_RESOLUTION=720p
VIDEO_DURATION=8

# 5. TTS (Text to Speech) - ElevenLabs
# Wiro (required for story/gen: gpt-oss-20b, gpt-5-nano; optional HMAC for some endpoints)
WIRO_API_KEY=your_wiro_api_key_here
WIRO_API_SECRET=your_wiro_api_secret_here
# Optional: task wait timeout in seconds (default 120)
# WIRO_TASK_TIMEOUT_SECONDS=120

# TTS Configuration (via Wiro)
TTS_MODEL=elevenlabs/text-to-speech
TTS_VOICE=21m00Tcm4TlvDq8ikWAM
TTS_FORMAT=mp3_22050_32

# ElevenLabs (Traditional API - Optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Images (Wiro - Google Imagen)
IMAGEN_API_KEY=your_wiro_api_key_here
IMAGEN_FAST_MODEL=google/imagen-v4-fast        # Hızlı üretim için
IMAGEN_ULTRA_MODEL=google/imagen-v4-ultra      # Kapak/hero görseller için

# ============================================
# LEGACY SUPPORT (Backward compatibility)
# ============================================
OPENAI_API_KEY=your_wiro_api_key_here
OPENAI_BASE_URL=https://api.wiro.ai/v1

# ============================================
# DATABASE
# ============================================
# Lokal: Aşağıdaki gibi kendiniz tanımlayın (şifre ve DB adı sizin).
# Docker: docker-compose backend servisinde DATABASE_URL otomatik atanır
#         (postgres konteynerine bağlanır); sadece DATABASE_PASSWORD kullanılır.
DATABASE_URL=postgresql://admin:CHANGE_THIS_PASSWORD@localhost:5432/masalfabrikasi
DATABASE_PASSWORD=CHANGE_THIS_PASSWORD
REDIS_URL=redis://localhost:6379/0

# ============================================
# SECURITY
# ============================================
DEBUG=false
# CRITICAL: Generate a secure random key for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_SECURE_RANDOM_KEY_HERE

# ============================================
# OPTIONAL SERVICES
# ============================================

# Supabase - Auth & Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Cloudinary - Opsiyonel; ana storage Supabase Storage kullanilir (cloud_storage_service)
# Supabase kullanilmiyorsa alternatif olarak Cloudinary entegre edilebilir
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# iyzico - Ödemeler (Türkiye)
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=sandbox-api.iyzipay.com
# Canlı ortam: IYZICO_BASE_URL=api.iyzipay.com

# Stripe - Payments (opsiyonel)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
STRIPE_PRICE_ID_PREMIUM_MONTHLY=
STRIPE_PRICE_ID_PRO_MONTHLY=

# Sentry - Error Tracking
SENTRY_DSN=https://your_sentry_dsn_here

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
APP_VERSION=1.0.0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Feature flags
USE_ASYNC_JOBS=true
USE_CLOUD_STORAGE=true

# Rate limiting (istek/dakika)
RATE_LIMIT_FREE_TIER=5
RATE_LIMIT_PREMIUM_TIER=50
RATE_LIMIT_PRO_TIER=500

# JWT (Auth)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP (Email - opsiyonel)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional: Enable query logging for performance monitoring
ENABLE_QUERY_LOGGING=false
